# BIMOS Environment Configuration
# Copy this file to .env and fill in the values.

# ── Server ────────────────────────────────────────────────────────────────────
BIMOS_HOST=127.0.0.1
BIMOS_PORT=8000
BIMOS_DEBUG=false

# ── Container image ───────────────────────────────────────────────────────────
# Name of the global BIMOS container image.
# Build it with: bimos setup
BIMOS_IMAGE=bimos/global:latest

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Example for a local Docker/Podman Postgres:
#   podman run -d --name bimos-db -e POSTGRES_USER=bimos \
#              -e POSTGRES_PASSWORD=bimos -e POSTGRES_DB=bimos \
#              -p 5432:5432 postgres:16
BIMOS_DATABASE_URL=postgresql://bimos:bimos@localhost/bimos

# ── QM tools (host binaries, not containerized) ───────────────────────────────
# Full path to the ORCA executable.
# Leave empty to disable QM calculations.
ORCA_PATH=/opt/orca/orca

# Full path to the Gaussian executable (g16, g09, etc.)
# Leave empty to disable Gaussian calculations.
GAUSSIAN_PATH=
